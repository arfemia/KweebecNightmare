// Kweebec CLASH (team PvP) round HUD: a match countdown, the coloured team-vs-team score,
// the viewer's team name, their personal hits/kills tally, and the per-team alive counts.
// Texture-free (colour-only) so it cannot red-X on a missing asset, mirroring
// KweebecNightmareHud.ui. Element ids (#MatchTimer/#TeamScore/#YourTeam/#Tally/#Alive) are
// the contract ClashHud pushes partial updates against. #TeamScore is the ONE rich line: it
// is driven via TextSpans (the <color is="#hex"> markup in the lang value is parsed client-
// side, per-locale); the rest are plain .Text. All five are code-driven each tick, so the
// literals here are placeholders, never shown once a frame is pushed.

@KnClashTimerStyle = (FontSize: 18, TextColor: #e6e0c8, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Start);
@KnClashScoreStyle = (FontSize: 22, TextColor: #dee2ef, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Start);
@KnClashTeamStyle  = (FontSize: 13, TextColor: #9fc6d0, RenderBold: false, HorizontalAlignment: Center, VerticalAlignment: Start);
@KnClashLineStyle  = (FontSize: 14, TextColor: #c8d2e0, RenderBold: false, HorizontalAlignment: Center, VerticalAlignment: Start);

Group {
  Group #KweebecClashHud {
    Anchor: (Top: 24, Width: 360, Height: 132, Horizontal: 0);
    LayoutMode: Top;

    Label #MatchTimer {
      Text: "Time 5:00";
      Anchor: (Height: 24);
      Style: @KnClashTimerStyle;
    }

    // #TeamScore is rich-text (coloured your-vs-enemy); ClashHud sets #TeamScore.TextSpans.
    Label #TeamScore {
      Anchor: (Height: 28);
      Style: @KnClashScoreStyle;
    }

    Label #YourTeam {
      Text: "Red";
      Anchor: (Height: 18);
      Style: @KnClashTeamStyle;
    }

    Label #Tally {
      Text: "Hits 0";
      Anchor: (Height: 20);
      Style: @KnClashLineStyle;
    }

    Label #Alive {
      Text: "Alive 1/1";
      Anchor: (Height: 20);
      Style: @KnClashLineStyle;
    }
  }
}

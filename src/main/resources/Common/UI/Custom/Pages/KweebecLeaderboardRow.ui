$C = "../Common.ui";

// One ranked leaderboard row (appended into #LeaderboardList; see KweebecLeaderboardPage).
// Colour-only (no textures) so it cannot red-X on a missing asset. Column widths align with
// #TableHeader in the page. Java sets #Rank/#PlayerName/#Score/#BestTime/#Plays, may override
// #Rank.Style.TextColor (gold/silver/bronze for the top 3), and may override .Background for the
// viewer's own row.

Group #LeaderboardRow {
  LayoutMode: Left;
  Anchor: (Height: 36, Bottom: 3);
  Padding: (Left: 8, Right: 8);
  Background: #1a2633;

  Label #Rank       { Text: ""; Anchor: (Width: 60);  Style: (FontSize: 15, TextColor: #ffaa4a, RenderBold: true, VerticalAlignment: Center); }
  Label #PlayerName { Text: ""; FlexWeight: 1;         Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center); }
  Label #Score      { Text: ""; Anchor: (Width: 120); Style: (FontSize: 14, TextColor: #7affa0, RenderBold: true, VerticalAlignment: Center); }
  Label #BestTime   { Text: ""; Anchor: (Width: 110); Style: (FontSize: 13, TextColor: #9fc6d0, VerticalAlignment: Center); }
  Label #Plays      { Text: ""; Anchor: (Width: 90);  Style: (FontSize: 13, TextColor: #96a9be, VerticalAlignment: Center); }
}

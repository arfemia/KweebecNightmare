# Guide dialogue: the Grove Warden (id "nightmares_intro"; backstory + the preset
# launcher). Rich text uses Hytale native inline formatting (<i>/<b>/<color>/\n).
dialogue.nightmares_intro.npc = The Grove Warden
dialogue.nightmares_intro.greet.text = A small Kweebec, its bark still <color is="#7affa0">green</color>, steps from the roots and looks up at you.\n<i>"You are warm. You are awake. Most of my kin are neither, not since the <color is="#a06cff">Void</color> crept into the grove. I am what is left to warn the warm ones."</i>
dialogue.nightmares_intro.greet.opt.0 = What happened to this place?
dialogue.nightmares_intro.greet.opt.1 = I am ready. Send me into the grove.
dialogue.nightmares_intro.greet.opt.2 = About the hunt I have already chosen...
dialogue.nightmares_intro.lore.text = <i>"Once the Emerald Grove <b>sang</b>. The <color is="#a06cff">Void</color> seeped up through the roots, and the song became screaming. My kin wear our faces now, and they <color is="#ff6b6b">hunt</color>."</i>\n<i>"Relight the grove-shrines and the Heartwood Gate will open. Linger too long, and the dark takes whoever runs last."</i>
dialogue.nightmares_intro.lore.opt.0 = Enough. I am ready to hunt.
dialogue.nightmares_intro.lore.opt.1 = Tell me something else.
dialogue.nightmares_intro.preset_pick.text = <i>"How deep will you go?"</i> The warden's eyes flicker like dying embers. <i>"Choose, and I will open a way into the dark."</i>
dialogue.nightmares_intro.preset_pick.opt.0 = <color is="#7affa0">Amateur</color> - let me learn the grove.
dialogue.nightmares_intro.preset_pick.opt.1 = <color is="#ffd479">Nightmare</color> - the true hunt.
dialogue.nightmares_intro.preset_pick.opt.2 = <color is="#ff6b6b">Hardcore</color> - one life, no mercy.
dialogue.nightmares_intro.preset_pick.opt.3 = Not yet. Step back.
dialogue.nightmares_intro.already_engaged.text = <i>"You are already bound to a hunt, warm one,"</i> the warden murmurs. <i>"Step out of the gathering first, and I will offer you the choice again."</i>
dialogue.nightmares_intro.already_engaged.opt.0 = I understand.

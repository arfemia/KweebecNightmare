# Clash Host NPC + the clash_intro dialogue (the PvP entry).
npc.clashhost.name = The Duelmaster
npc.clashhost.hint = Press [{key}] to enter the arena
dialogue.clash_intro.npc = The Duelmaster
dialogue.clash_intro.greet.text = A scarred Kweebec leans on a thorned staff and sizes you up. <i>"So. You would test your roots against another warm-blood. The grove makes a fine arena, when the hunt is each other."</i>
dialogue.clash_intro.greet.opt.0 = How does the arena work?
dialogue.clash_intro.greet.opt.1 = I am ready to fight.
dialogue.clash_intro.greet.opt.2 = About the match I have joined...
dialogue.clash_intro.lore.text = <i>"Two teams. Knockback and stun shrooms sprout from the soil - grab them, throw them, take no chances. Last team standing wins; if the timer runs dry, the team that landed the most blows takes it. In Domination, hold the ground instead."</i>
dialogue.clash_intro.lore.opt.0 = Enough talk. Let me fight.
dialogue.clash_intro.lore.opt.1 = Wait, tell me more.
dialogue.clash_intro.mode_pick.text = <i>"Name your contest, warm-blood."</i>
dialogue.clash_intro.mode_pick.opt.0 = Clash 1v1 - just the two of us.
dialogue.clash_intro.mode_pick.opt.1 = Clash 2v2 - bring an ally.
dialogue.clash_intro.mode_pick.opt.2 = Domination - hold the ground.
dialogue.clash_intro.mode_pick.opt.3 = Not yet. Step back.
dialogue.clash_intro.already_engaged.text = <i>"You are already in a contest, warm-blood,"</i> the Duelmaster grunts. <i>"Finish it, then return."</i>
dialogue.clash_intro.already_engaged.opt.0 = Understood.

# Dialogue page chrome (resolved by the shared ziggfreed-common dialogue engine).
ui.dialogue.farewell = Step away
ui.dialogue.missing = The voice fades. Nothing more comes.

# Demo dialogue: the Whispering Sapling (id "kweebec_intro"; keys are by-convention
# dialogue.<id>.<node>.text and dialogue.<id>.<node>.opt.<index>).
dialogue.kweebec_intro.npc = The Whispering Sapling
dialogue.kweebec_intro.greet.text = A pale sapling turns its hollow eyes toward you. "You still breathe," it rasps. "Few do, this deep in the blight."
dialogue.kweebec_intro.greet.opt.0 = What is this place?
dialogue.kweebec_intro.greet.opt.1 = What hunts in the dark?
dialogue.kweebec_intro.greet.opt.2 = You spoke of a warning. Tell me what the grove hid.
dialogue.kweebec_intro.lore.text = "Once the Emerald Grove sang. The Void crept in through the roots, and the song turned to screaming. We are what is left of the singers."
dialogue.kweebec_intro.lore.opt.0 = Go back
dialogue.kweebec_intro.warning.text = "It wears our bark and our faces. It does not tire. When a shrine flares, it turns toward the light, and toward you."
dialogue.kweebec_intro.warning.opt.0 = Go back
dialogue.kweebec_intro.secret.text = The sapling leans close. "The Heartwood Gate is not an exit. It is a mouth. Relight every shrine, or it swallows whoever runs last."
dialogue.kweebec_intro.secret.opt.0 = Go back


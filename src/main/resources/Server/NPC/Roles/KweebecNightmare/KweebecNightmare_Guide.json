{
  "$Comment": "KweebecNightmare - the 'Grove Warden' guide NPC (a surviving uncorrupted Kweebec). Stationary + invulnerable + neutral; press-F opens the backstory + preset-launcher dialogue 'nightmares_intro' via the ziggfreed-common ZigOpenDialogue action (registered in plugin setup() BEFORE this role loads). Copied from the MMO's MMO_QuestGiver shape; the dialogue id is baked on the param (no Target:auto placement registry).",
  "Type": "Generic",
  "Parameters": {
    "NameTranslationKey": {
      "Value": "kweebecnightmare.npc.guide.name",
      "Description": "Display name for the Grove Warden guide NPC"
    }
  },
  "StartState": "Idle",
  "DefaultNPCAttitude": "Ignore",
  "DefaultPlayerAttitude": "Neutral",
  "Appearance": "Kweebec_Rootling",
  "MaxHealth": 100,
  "IsMemory": false,
  "DisableDamageGroups": [ "Self" ],
  "CombatConfig": {
    "EntityEffect": "Immunity_Environmental"
  },
  "BusyStates": [ "$Interaction" ],
  "Invulnerable": true,
  "KnockbackScale": 0.0,
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": 5,
      "Gravity": 10,
      "RunThreshold": 0.3,
      "MaxFallSpeed": 15,
      "MaxRotationSpeed": 360,
      "Acceleration": 10
    }
  ],
  "Instructions": [
    {
      "Instructions": [
        {
          "$Comment": "Idle - no player nearby; stand still.",
          "Sensor": { "Type": "State", "State": "Idle" },
          "Instructions": [
            {
              "$Comment": "Wave at an approaching player, then watch.",
              "ActionsBlocking": true,
              "Sensor": { "Type": "Player", "Range": 8 },
              "Actions": [
                { "Type": "PlayAnimation", "Slot": "Status", "Animation": "Wave" },
                { "Type": "State", "State": "Watching" }
              ]
            },
            { "Sensor": { "Type": "Any" }, "BodyMotion": { "Type": "Nothing" } }
          ]
        },
        {
          "$Comment": "Watching - player nearby; track with head, STOP the wave after a beat (clear the looping Status slot), return to Idle when they leave.",
          "Sensor": { "Type": "State", "State": "Watching" },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "Player", "Range": 12 },
              "HeadMotion": { "Type": "Watch" }
            },
            {
              "Continue": true,
              "Sensor": { "Type": "Any" },
              "Actions": [
                { "Type": "Timeout", "Delay": [ 2, 2 ], "Action": { "Type": "PlayAnimation", "Slot": "Status" } }
              ]
            },
            {
              "Sensor": { "Type": "Not", "Sensor": { "Type": "Player", "Range": 12 } },
              "Actions": [
                { "Type": "PlayAnimation", "Slot": "Status" },
                { "Type": "State", "State": "Idle" }
              ]
            },
            { "Sensor": { "Type": "Any" }, "BodyMotion": { "Type": "Nothing" } }
          ]
        },
        {
          "$Comment": "Interaction - the dialogue page is open; look at the player, then return to Watching.",
          "Sensor": { "Type": "State", "State": "$Interaction" },
          "Instructions": [
            {
              "Continue": true,
              "Sensor": { "Type": "Target", "Range": 10 },
              "HeadMotion": { "Type": "Watch" }
            },
            {
              "Sensor": { "Type": "Any" },
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": [ 1, 1 ],
                  "Action": {
                    "Type": "Sequence",
                    "Actions": [
                      { "Type": "ReleaseTarget" },
                      { "Type": "State", "State": "Watching" }
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "InteractionInstruction": {
    "Instructions": [
      {
        "Sensor": { "Type": "Not", "Sensor": { "Type": "CanInteract", "ViewSector": 180 } },
        "Actions": [ { "Type": "SetInteractable", "Interactable": false } ]
      },
      {
        "Continue": true,
        "Sensor": { "Type": "Any" },
        "Actions": [ { "Type": "SetInteractable", "Interactable": true, "Hint": "kweebecnightmare.npc.guide.hint" } ]
      },
      {
        "Sensor": { "Type": "HasInteracted" },
        "Instructions": [
          {
            "Sensor": { "Type": "Not", "Sensor": { "Type": "State", "State": "$Interaction" } },
            "Actions": [
              { "Type": "LockOnInteractionTarget" },
              { "Type": "ZigOpenDialogue", "Dialogue": "nightmares_intro", "ContextNpc": "guide" },
              { "Type": "State", "State": "$Interaction" }
            ]
          }
        ]
      }
    ]
  },
  "NameTranslationKey": { "Compute": "NameTranslationKey" }
}

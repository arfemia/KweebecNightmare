                "AttackDistance": { "Compute": "AttackDistance" },
                "TargetRange": 5,
                "CombatRelativeTurnSpeed": { "Compute": "CombatRelativeTurnSpeed" }
              }
            },
            {
              "$Comment": "LUNGER attack motion: a Charge lunge replaces the plain Intelligent_Chase. Out past melee the hunter winds up briefly then bursts at the target (ChargeAbsoluteSpeed), spawning a Void burst on each charge phase. After/aside the charge it still pursues relentlessly (no soft leash, filterless target, the de-leashed contract). The Charge sensor lives on a Continue branch so the trailing Seek fallback ALWAYS runs and the role never stalls if a charge is obstructed - a wrong charge degrades to a fast stalker, never a broken role.",
              "Continue": true,
              "Sensor": {
                "Type": "Target",
                "Range": { "Compute": "AlertedRange" }
              },
              "BodyMotion": {
                "Type": "Charge",
                "ClearOnceOnStateChange": true,
                "RelativeTurnSpeed": 1,
                "LockedOnToleranceAngle": 30,
                "LockedOnDurationRange": [ 0.2, 0.4 ],
                "WindingUpDurationRange": [ 0.4, 0.7 ],
                "PostChargeDurationRange": [ 0.6, 1.0 ],
                "WindingUpUninterruptable": true,
                "WindingUpRelativeTurnSpeed": 1,
                "ChargeRelativeSpeed": 0,
                "ChargeDistanceRange": [ 6, 12 ],
                "ChargeAbsoluteSpeed": 16,
                "ChargeAcceleration": 1000,
                "IgnoredBlockSetTriggers": false,
                "EntityStopsCharge": false,
                "ClimbSlope": 2,
                "DropSlope": 2,
                "HorizontalSkipGapWidth": 1.2
              }
            },
            {
              "Continue": true,
              "Sensor": {
                "Type": "ChargeState",
                "Once": true,
                "States": [ "WindingUp" ]
              },
              "Actions": [
                {
                  "Type": "SpawnParticles",
                  "Offset": [ 0, 1.2, 0 ],
                  "ParticleSystem": "Angry"
                }
